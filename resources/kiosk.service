[Unit]
Description=Wayland Audio Kiosk
After=login.target systemd-user-sessions.service

[Service]
User=avk
WorkingDirectory=/home/yourusername/your_app_directory
Environment=XDG_RUNTIME_DIR=/run/user/1000
Environment=WLR_RENDERER=pixman
# This line handles your execution natively with full group access
ExecStart=/usr/bin/cage -s -- .venv/bin/python3 home/avk/kiosk/audio_mixing_kiosk/src/gui.py
Restart=always
RestartSec=3

[Install]
WantedBy=graphical.target